<!-- Admin CSS -->
<link rel="stylesheet" href="/css/admin.css">

{{!-- User Management Page --}}
<div class="admin-container">
  {{!-- Page Header --}}
  <div class="admin-header">
    <h1><i class="fas fa-users-cog"></i> User Management</h1>
    <p class="admin-subtitle">View and manage user accounts</p>
    <div class="header-actions">
      <a href="/admin" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back to Dashboard
      </a>
    </div>
  </div>

  {{!-- Alert Messages --}}
  {{#if messages.success}}
    <div class="alert alert-success">
      <i class="fas fa-check-circle"></i>
      {{messages.success}}
    </div>
  {{/if}}

  {{#if messages.error}}
    <div class="alert alert-error">
      <i class="fas fa-exclamation-circle"></i>
      {{messages.error}}
    </div>
  {{/if}}

  {{!-- Search and Filter Controls --}}
  <div class="controls-panel">
    <div class="search-section">
      <div class="search-input-wrapper">
        <i class="fas fa-search"></i>
        <input
          type="text"
          id="userSearch"
          placeholder="Search users by email or name..."
          class="search-input"
        >
      </div>
      <button class="btn btn-primary" onclick="searchUsers()">
        <i class="fas fa-search"></i> Search
      </button>
      <button class="btn btn-secondary" onclick="clearSearch()">
        <i class="fas fa-times"></i> Clear
      </button>
    </div>

    <div class="filter-section">
      <div class="filter-group">
        <label for="statusFilter">Status:</label>
        <select id="statusFilter" class="filter-select">
          <option value="">All Users</option>
          <option value="active">Active Only</option>
          <option value="inactive">Inactive Only</option>
        </select>
      </div>

      <div class="filter-group">
        <label for="roleFilter">Role:</label>
        <select id="roleFilter" class="filter-select">
          <option value="">All Roles</option>
          <option value="user">Users</option>
          <option value="admin">Admins</option>
        </select>
      </div>

      <div class="filter-group">
        <label for="limitFilter">Per Page:</label>
        <select id="limitFilter" class="filter-select">
          <option value="20">20</option>
          <option value="50">50</option>
          <option value="100">100</option>
        </select>
      </div>

      <button class="btn btn-info" onclick="applyFilters()">
        <i class="fas fa-filter"></i> Apply Filters
      </button>
    </div>
  </div>

  {{!-- Users Table --}}
  <div class="table-container">
    <div class="table-header">
      <h2><i class="fas fa-list"></i> Users</h2>
      <div class="table-info">
        <span id="userCount">Loading...</span>
      </div>
    </div>

    <div class="table-wrapper">
      <table class="users-table">
        <thead>
          <tr>
            <th>
              <span class="sortable" onclick="sortUsers('email')">
                Email <i class="fas fa-sort"></i>
              </span>
            </th>
            <th>Display Name</th>
            <th>
              <span class="sortable" onclick="sortUsers('role')">
                Role <i class="fas fa-sort"></i>
              </span>
            </th>
            <th>
              <span class="sortable" onclick="sortUsers('status')">
                Status <i class="fas fa-sort"></i>
              </span>
            </th>
            <th>
              <span class="sortable" onclick="sortUsers('createdAt')">
                Created <i class="fas fa-sort"></i>
              </span>
            </th>
            <th>Notes</th>
            <th>Last Login</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="usersTableBody">
          <tr>
            <td colspan="8" class="loading-row">
              <div class="loading">
                <i class="fas fa-spinner fa-spin"></i>
                Loading users...
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Pagination --}}
  <div class="pagination-container">
    <div class="pagination-info">
      <span id="paginationInfo">Loading...</span>
    </div>
    <div class="pagination-controls">
      <button id="prevPageBtn" class="btn btn-secondary" onclick="previousPage()" disabled>
        <i class="fas fa-chevron-left"></i> Previous
      </button>
      <div class="page-numbers" id="pageNumbers">
        <!-- Generated by JavaScript -->
      </div>
      <button id="nextPageBtn" class="btn btn-secondary" onclick="nextPage()" disabled>
        Next <i class="fas fa-chevron-right"></i>
      </button>
    </div>
  </div>

  {{!-- User Details Modal --}}
  <div id="userDetailsModal" class="modal" style="display: none;">
    <div class="modal-overlay" onclick="closeUserDetailsModal()"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h3><i class="fas fa-user"></i> User Details</h3>
        <button class="modal-close" onclick="closeUserDetailsModal()">&times;</button>
      </div>

      <div class="modal-body">
        <div id="userDetailsContent">
          <div class="loading">Loading user details...</div>
        </div>
      </div>
    </div>
  </div>

  {{!-- Status Change Confirmation Modal --}}
  <div id="statusConfirmModal" class="modal" style="display: none;">
    <div class="modal-overlay" onclick="closeStatusConfirmModal()"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h3><i class="fas fa-exclamation-triangle"></i> Confirm Status Change</h3>
        <button class="modal-close" onclick="closeStatusConfirmModal()">&times;</button>
      </div>

      <div class="modal-body">
        <div class="warning-box">
          <p><strong>Are you sure you want to <span id="statusAction">change</span> this user's status?</strong></p>
          <p>User: <strong id="statusUserEmail"></strong></p>
          <p id="statusWarning"></p>
        </div>

        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="closeStatusConfirmModal()">
            <i class="fas fa-times"></i> Cancel
          </button>
          <button type="button" class="btn btn-warning" id="confirmStatusBtn" onclick="confirmStatusChange()">
            <i class="fas fa-check"></i> Confirm
          </button>
        </div>
      </div>
    </div>
  </div>

  {{!-- Bulk Actions (Future Enhancement) --}}
  <div class="bulk-actions" style="display: none;" id="bulkActionsPanel">
    <div class="bulk-header">
      <span><strong id="selectedCount">0</strong> users selected</span>
      <button class="btn btn-info" onclick="selectAllVisible()">Select All</button>
      <button class="btn btn-secondary" onclick="clearSelection()">Clear</button>
    </div>
    <div class="bulk-buttons">
      <button class="btn btn-warning" onclick="bulkStatusChange('activate')">
        <i class="fas fa-user-check"></i> Activate Selected
      </button>
      <button class="btn btn-danger" onclick="bulkStatusChange('deactivate')">
        <i class="fas fa-user-times"></i> Deactivate Selected
      </button>
    </div>
  </div>
</div>

{{!-- Loading overlay --}}
<div id="loadingOverlay" class="loading-overlay" style="display: none;">
  <div class="loading-spinner">
    <i class="fas fa-spinner fa-spin"></i>
    <span>Processing...</span>
  </div>
</div>

<!-- Admin JavaScript -->
<script src="/js/admin.js"></script>